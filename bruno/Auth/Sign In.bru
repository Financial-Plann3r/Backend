meta {
  name: Sign In
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/signin
  body: json
  auth: none
}

body:json {
  {
    "email": "user@example.com",
    "password": "password123"
  }
}

script:post-response {
  if (res.status === 200 && res.body.data && res.body.data.session) {
    bru.setVar("jwt_token", res.body.data.session.access_token);
  }
}
