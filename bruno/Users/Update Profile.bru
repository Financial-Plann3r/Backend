meta {
  name: Update Profile
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/api/users/profile
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{jwt_token}}
}

body:json {
  {
    "displayName": "Ryan Baru",
    "preferences": {
      "darkMode": true,
      "currency": "IDR"
    }
  }
}
